/**
 * Central Wi‑Fi credentials for every sketch under ESP32/ (env, biometric, mock, etc.).
 *
 * Copy this file to ``secrets.h`` in this same folder (``ESP32/secrets.h``).
 * In each sketch folder, use: ``#include "../secrets.h"``
 *
 * ``secrets.h`` is gitignored — never commit real passwords.
 */
#ifndef ESP32_SECRETS_H
#define ESP32_SECRETS_H

#define WIFI_SSID "your-wifi-ssid"
#define WIFI_PASSWORD "your-wifi-password"

#endif
