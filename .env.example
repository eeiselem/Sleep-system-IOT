# Copy to `.env` and fill in locally. Never commit `.env`.

# Flask bind (default 8888). For Cloudflare Tunnel, set FLASK_USE_SSL=0 and point cloudflared at http://127.0.0.1:8888
FLASK_PORT=8888
# 1 = adhoc HTTPS on LAN (default). 0 = plain HTTP for cloudflared origin (TLS only at Cloudflare edge).
FLASK_USE_SSL=1

# Flask session signing (use a long random string, e.g. `python -c "import secrets; print(secrets.token_hex(32))"`)
FLASK_SECRET_KEY=

# AES at-rest + transport decrypt (server + ESP32 `MASTER_ENC_SECRET_UTF8` must match this exact UTF-8 string)
MASTER_ENCRYPTION_KEY=

# ESP32 POST /post-data auth — must match `INGEST_API_KEY_STR` in ESP32.ino
INGEST_API_KEY=

# Optional: OpenAI — sleep coach / LLM features in app.py
OPENAI_API_KEY=
# Optional model override (default gpt-4o-mini)
OPENAI_SLEEP_COACH_MODEL=gpt-4o-mini
# Optional cap on context size for coach
SLEEP_COACH_CONTEXT_CHARS=340000

# Optional safety clamp for MQ135-style index in server logic (default 420)
MQ135_SAFE_INDEX_MAX=420

# Optional: teammate ``biometric.ino`` AES-128-CBC (15-char literals are zero-padded to 16 bytes, matching ESP32)
# BIOMETRIC_AES_KEY=ThisIsKeyAES333
# BIOMETRIC_AES_IV=ThisIsVectorIV7
